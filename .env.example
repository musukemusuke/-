# Botの基本設定
DISCORD_TOKEN=your_bot_token_here
# ログレベル（DEBUG/INFO/WARNING/ERRORから選択、デフォルトINFO）
LOG_LEVEL=INFO
# 権限設定失敗時の最大リトライ回数（デフォルト3）
MAX_RETRY_COUNT=3
# リトライ間隔（秒、デフォルト3秒）
RETRY_INTERVAL_SECONDS=3
# ヘルスチェック用HTTPサーバーのポート（デフォルト8080）
HEALTH_CHECK_PORT=8080
# エラー通知用のDiscordチャンネルID（設定すると重大なエラーが発生した際に自動通知）
ERROR_NOTIFICATION_CHANNEL_ID=your_error_channel_id

# ボイスチャンネル関連設定
# 休止ボイスチャンネルのID（カンマ区切りで複数指定可能）
IGNORE_VOICE_CHANNEL_IDS=1234567890,0987654321
# 常設ボイスチャンネルの名前（カンマ区切りで複数指定可能）
PERMANENT_VOICE_NAMES=フリー,まったり
# アーカイブ済みチャット履歴を投稿するチャンネルID
ARCHIVE_CHANNEL_ID=1521780512795132015
# 以下は現在のアーキテクチャでは使用されていない旧設定（将来必要になった場合にコメント解除して使用可）
# # ボイスチャンネル作成用のチャンネルID
# CREATE_VOICE_CHANNEL_ID=your_create_voice_channel_id

# 権限・ロール関連設定（現在の個人ロール自動生成設計では不要なためコメントアウト）
# 管理者ロールID（カンマ区切りで複数指定可能）
# ADMIN_ROLE_IDS=your_admin_role_ids
# メンバーロールID
# MEMBER_ROLE_ID=your_member_role_id
# 全チャンネル閲覧ロールID
# VIEW_ALL_CHANNELS_ROLE_ID=your_view_all_channels_role_id
# 権限設定を適用するカテゴリID（カンマ区切りで複数指定可能、現在の設計では不要なためコメントアウト）
# CATEGORY_IDS=your_category_ids

# チャンネル設定
# 読み取り専用にするチャンネルID（カンマ区切りで複数指定可能）
# お知らせ(1520972406234153081)、守ってほしい事(1520972441151733911)を指定
READ_ONLY_CHANNEL_IDS=1520972406234153081,1520972441151733911,1524195864514400527